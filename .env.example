# PostgreSQL
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
DATABASE_URL=Host=localhost;Port=5432;Database=your_db_name;Username=your_db_user;Password=your_db_password

# Stockage fichiers
# Local (MinIO) :
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=sharenspare-uploads
STORAGE_PUBLIC_URL=http://localhost:9000/sharenspare-uploads
# Production (Cloudflare R2) :
# STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=your_r2_access_key_id
# STORAGE_SECRET_KEY=your_r2_secret_access_key
# STORAGE_BUCKET=sharenspare-uploads
# STORAGE_PUBLIC_URL=https://pub-xxxx.r2.dev

# MinIO Docker (dev uniquement)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Mailhog (dev uniquement)
SMTP_HOST=localhost
SMTP_PORT=1025

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_ISSUER=ShareNSpare
JWT_AUDIENCE=ShareNSpare
JWT_EXPIRATION_HOURS=24

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PLATFORM_FEE_PERCENT=15

# Frontend
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-public-token
NEXT_PUBLIC_API_URL=http://localhost:5148

# Seed passwords (optionnel)
SEED_ADMIN_PASSWORD=your-admin-seed-password
SEED_DEFAULT_PASSWORD=your-default-seed-password
